{
  "name": "silsigan",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "cap:sync": "capacitor sync",
    "cap:sync:ios:local": "CAPACITOR_SERVER_URL=http://localhost:3000 capacitor sync ios",
    "cap:sync:android:local": "CAPACITOR_SERVER_URL=http://10.0.2.2:3000 capacitor sync android",
    "cap:open:ios": "capacitor open ios",
    "cap:open:android": "capacitor open android",
    "mobile:sync": "pnpm cap:sync",
    "mobile:open:ios": "pnpm cap:open:ios",
    "mobile:open:android": "pnpm cap:open:android"
  },
  "dependencies": {
    "@capacitor/core": "^8.3.4",
    "@supabase/supabase-js": "2.98.0",
    "lucide-react": "0.575.0",
    "next": "16.2.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "0.34.5",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "eslint": "9.39.1",
    "eslint-config-next": "16.1.6",
    "typescript": "5.8.2"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@<2.0.0": "1.1.13",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
      "flatted": "3.4.2",
      "picomatch@<4.0.0": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss": "8.5.10",
      "tar": "7.5.11"
    }
  }
}
